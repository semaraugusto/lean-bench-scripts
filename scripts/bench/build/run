#!/usr/bin/env bash
set -euxo pipefail

BENCH="$RADAR_BENCH_REPO/scripts/bench"

# Run lake commands from the repo root
cd "$RADAR_REPO"

echo "adding symlink...."
ln -sfn "$(lean --print-prefix)/include" "$BENCH/build/fake-root/include"
ln -sfn "$(lean --print-prefix)/lib" "$BENCH/build/fake-root/lib"

# Prepare build (cache is only available for Mathlib-dependent projects)
lake exe cache get || true

lake build Aeneas

# Run build
LAKE_OVERRIDE_LEAN=true LEAN=$(realpath "$BENCH/build/fake-root/bin/lean") \
  "$BENCH/measure.py" -t build \
  -m instructions -m maxrss -m task-clock -m wall-clock -- \
  lakeprof record lake build --no-cache

# Analyze lakeprof data
lakeprof report -pj | jq -c '{metric: "build/lakeprof/longest build path//wall-clock", value: .[-1][2], unit: "s"}' >> "$RADAR_OUT"
lakeprof report -rj | jq -c '{metric: "build/lakeprof/longest rebuild path//wall-clock", value: .[-1][2], unit: "s"}' >> "$RADAR_OUT"

# Upload lakeprof report
# Guarded to prevent accidental uploads (which wouldn't work anyways) during local runs.
if [ -f build_upload_lakeprof_report ]; then
  python3 "$BENCH/build/lakeprof_report_upload.py"
fi
